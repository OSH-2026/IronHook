# Copy to config/experiment.env and edit local paths.
# Source this file from the Lab4 directory, or replace LAB4_DIR with an absolute path.

LAB4_DIR="${LAB4_DIR:-$PWD}"

export LLAMA_CPP_DIR="$LAB4_DIR/llama.cpp"
export MODEL_PATH="$LAB4_DIR/models/qwen2.5-1.5b-instruct-q4_k_m.gguf"
export MODEL_NAME="Qwen2.5-1.5B-Instruct"
export QUANTIZATION="Q4_K_M"

# Build options: cpu, cuda, metal, hip, vulkan.
export BACKEND="cpu"
export GGML_RPC="ON"
export BUILD_DIR="build"
export JOBS="8"

# llama.cpp runtime defaults.
export THREADS="8"
export CTX_SIZE="2048"
export BATCH_SIZE="256"
export N_GPU_LAYERS="0"
export N_PREDICT="128"
export TEMPERATURE="0.2"

# llama-server defaults.
export SERVER_HOST="0.0.0.0"
export SERVER_PORT="8080"

# RPC defaults.
export RPC_PORT="50052"
export RPC_SERVERS="192.168.1.11:50052"

# Extra llama.cpp arguments, for example: "--mlock" or "--no-mmap".
export LLAMA_EXTRA_ARGS=""
