# Copy to config/experiment.env and edit local paths.

LLAMA_CPP_DIR="$HOME/llama.cpp"
MODEL_PATH="$PWD/models/qwen2.5-1.5b-instruct-q4_k_m.gguf"
MODEL_NAME="Qwen2.5-1.5B-Instruct"
QUANTIZATION="Q4_K_M"

# Build options: cpu, cuda, metal, hip, vulkan.
BACKEND="cpu"
GGML_RPC="ON"
BUILD_DIR="build"
JOBS="8"

# llama.cpp runtime defaults.
THREADS="8"
CTX_SIZE="2048"
BATCH_SIZE="256"
N_GPU_LAYERS="0"
N_PREDICT="128"
TEMPERATURE="0.2"

# llama-server defaults.
SERVER_HOST="0.0.0.0"
SERVER_PORT="8080"

# RPC defaults.
RPC_PORT="50052"
RPC_SERVERS="192.168.1.11:50052"

# Extra llama.cpp arguments, for example: "--mlock" or "--no-mmap".
LLAMA_EXTRA_ARGS=""
